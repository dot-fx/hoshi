{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hoshi",
  "version": "1.0.0",
  "identifier": "com.dot-fx.hoshi",
  "build": {
    "frontendDist": "../hoshi-frontend/build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "hoshi",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "transparent": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["hoshi"]
      },
      "mobile": [
        {
          "scheme": ["hoshi"],
          "appLink": false
        }
      ]
    }
  }
}